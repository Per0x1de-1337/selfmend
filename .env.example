# ── STT ──────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ── TTS ──────────────────────────────────────────────────────────────
CARTESIA_API_KEY=your_cartesia_api_key_here
CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091   # default voice, change freely

# ── LLM ──────────────────────────────────────────────────────────────
# Provider options: "groq" (recommended) | "openai" | "local" (Ollama)
LLM_PROVIDER=groq

# Groq (free tier, ~50ms TTFT) — https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# OpenAI fallback
OPENAI_API_KEY=your_openai_api_key_here

# Local Ollama (only faster than cloud if you have a GPU)
OLLAMA_MODEL=orca-mini
OLLAMA_URL=http://localhost:11434
